# ── EduGenie AI Service — .env ────────────────────────────────
# Copy this file to .env and fill in your values.

# Must match AI_API_KEY in Laravel's .env (services.ai.api_key)
AI_API_KEY=change-me-in-production

# Must match services.ai.webhook_secret in Laravel
WEBHOOK_SECRET=change-me-in-production

# Base URL of the Laravel application (for webhook deliveries)
LARAVEL_URL=http://localhost:8000

# ── Model paths ───────────────────────────────────────────────
# Path to your fine-tuned Qwen2+LoRA adapter directory
SCRIPT_ADAPTER_PATH=./models/script-adapter

# Path where the fine-tuned quiz FLAN-T5 model is saved
# (run the MCQ notebook Cell 10 and save to this path)
QUIZ_MODEL_PATH=./models/quiz-model

# Mistral-7B for slide JSON extraction (HF hub name or local path)
SLIDE_MODEL_NAME=mistralai/Mistral-7B-Instruct-v0.2

# SDXL image generation (leave empty to disable)
SDXL_MODEL_PATH=

# ── Asset paths ───────────────────────────────────────────────
AVATAR_WAVE_PATH=./assets/avatar_wave.png
AVATAR_STAND_PATH=./assets/avatar_stand.png
PPTX_TEMPLATE_PATH=./assets/template.pptx

# ── Storage ───────────────────────────────────────────────────
OUTPUT_DIR=./storage/outputs

# ── Concurrency ───────────────────────────────────────────────
MAX_WORKERS=1
